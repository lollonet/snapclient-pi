# Docker Image Tag
# Controls which image version is pulled for all 3 containers.
# Default: latest (stable release). Set to a dev tag for testing:
#   IMAGE_TAG=0.4.0-dev.1
IMAGE_TAG=latest

# Snapserver Configuration
# Leave empty for mDNS autodiscovery, or set IP/hostname manually.
# Also used as the metadata server address for fb-display.
SNAPSERVER_HOST=
SNAPSERVER_PORT=1704

# Client Configuration (auto-generated by setup.sh)
# CLIENT_ID is derived from hostname: snapclient-<hostname>
CLIENT_ID=snapclient-raspberrypi

# Audio Configuration (auto-configured by setup.sh)
# Must be "default" so audio routes through multi_out (DAC + loopback for spectrum)
# Direct hw: devices bypass the loopback and the spectrum analyzer gets silence
SOUNDCARD=default

# ALSA Buffer Tuning — applied to all ALSA devices
# Higher values prevent underruns but increase latency (affects multi-room sync)
# buffer_time in milliseconds (50-2000), fragments (2-16)
# Ethernet: 120-160ms / 4 fragments  |  WiFi: 200-300ms / 6-8 fragments
# Auto-configured by setup.sh based on connection type
ALSA_BUFFER_TIME=150
ALSA_FRAGMENTS=4

# Network Optimization (auto-configured by setup.sh)
# CONNECTION_TYPE: auto-detected as "ethernet" or "wifi"
# WiFi: power management disabled, higher ALSA buffers for jitter tolerance
# Ethernet: lower ALSA buffers for tighter multi-room sync
CONNECTION_TYPE=auto

# Application version (auto-set by setup.sh from git tag)
APP_VERSION=

# Mixer mode: software (default), hardware[:<element>], or none
# software         = snapclient attenuates audio before loopback (spectrum is volume-dependent)
# hardware:Digital = DAC controls volume, loopback gets full-scale audio (best for spectrum)
# none             = disable volume control (always full-scale, no way to change volume)
# Auto-configured by setup.sh based on detected HAT. Override only if needed.
# Common elements: "Digital" (HiFiBerry/IQaudio/JustBoom DACs), "Headphone" (IQaudio Codec),
#                  "Speaker" (Waveshare WM8960). S/PDIF and USB default to software.
MIXER=software

# Display Resolution (optional, auto-configured by setup.sh)
# Leave empty to auto-detect from framebuffer (capped at 1920x1080).
# Output is always scaled to actual framebuffer size.
DISPLAY_RESOLUTION=

# Audio sample rate (must match Snapserver: 44100 Hz is the snapMULTI standard)
SAMPLE_RATE=44100

# Spectrum Analyzer Band Resolution: half-octave (21 bands) or third-octave (31 bands)
BAND_MODE=third-octave

# Docker Compose profiles (auto-configured by setup.sh)
# Set to "framebuffer" to enable fb-display container
COMPOSE_PROFILES=

# ============================================================
# Resource Limits (auto-configured by setup.sh)
# ============================================================
# setup.sh detects your hardware and sets appropriate limits.
# Override manually if needed.
#
# Profiles:
#   minimal     - Pi Zero 2 W, Pi 3, <2GB RAM
#   standard    - Pi 4 2GB, 2-4GB RAM
#   performance - Pi 4 4GB+, Pi 5, 8GB+ RAM
#
# To reconfigure: ./scripts/setup.sh --auto <config>
# ============================================================

# Values below are for the standard profile. setup.sh overwrites them
# with the detected profile; only uncomment to override manually.
#
# Snapclient (core audio client) — measured idle: 18M
#SNAPCLIENT_MEM_LIMIT=64M
#SNAPCLIENT_MEM_RESERVE=32M
#SNAPCLIENT_CPU_LIMIT=0.5

# Audio Visualizer (spectrum analyzer) — measured idle: 36-51M
#VISUALIZER_MEM_LIMIT=128M
#VISUALIZER_MEM_RESERVE=64M
#VISUALIZER_CPU_LIMIT=1.0

# Framebuffer Display (fb-display profile) — measured: 89M (1080p), 114M (4K)
#FBDISPLAY_MEM_LIMIT=256M
#FBDISPLAY_MEM_RESERVE=128M
#FBDISPLAY_CPU_LIMIT=1.0

# ============================================================
# Read-Only Filesystem (optional)
# ============================================================
# Enable read-only root filesystem using overlayfs.
# Protects SD card from corruption on power loss.
# When enabled:
#   - Root filesystem is read-only (overlay on top of actual SD card)
#   - All writes go to RAM-backed tmpfs (lost on reboot)
#   - Docker uses fuse-overlayfs storage driver
#
# To temporarily disable for updates:
#   sudo ro-mode disable && sudo reboot
#   # Make changes...
#   sudo ro-mode enable && sudo reboot
#
# Note: Requires reboot after setup.sh completes
ENABLE_READONLY=true
