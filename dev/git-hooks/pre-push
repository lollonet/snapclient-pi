#!/usr/bin/env bash
# Pre-push hook - runs CI checks before pushing
# Bypass with: git push --no-verify

set -euo pipefail

echo "🔍 Running pre-push CI checks..."
echo ""

# Color output
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Track failures
FAILED=0

# Function to run check
run_check() {
    local name="$1"
    local cmd="$2"

    echo -e "${YELLOW}▶ ${name}${NC}"
    if eval "$cmd" > /dev/null 2>&1; then
        echo -e "${GREEN}✓ ${name} passed${NC}"
        return 0
    else
        echo -e "${RED}✗ ${name} failed${NC}"
        FAILED=$((FAILED + 1))
        return 1
    fi
}

# Shellcheck (match remote CI: only fail on warnings and errors, not info/style)
if command -v shellcheck &> /dev/null; then
    run_check "Shellcheck" "shellcheck --severity=warning common/scripts/*.sh tests/*.sh scripts/*.sh"
else
    echo -e "${YELLOW}⚠ Shellcheck not installed - skipping${NC}"
fi

# Hadolint
if command -v hadolint &> /dev/null; then
    run_check "Hadolint (snapclient)" "hadolint --config .hadolint.yaml common/docker/snapclient/Dockerfile"
    run_check "Hadolint (fb-display)" "hadolint --config .hadolint.yaml common/docker/fb-display/Dockerfile"
    run_check "Hadolint (audio-visualizer)" "hadolint --config .hadolint.yaml common/docker/audio-visualizer/Dockerfile"
else
    echo -e "${YELLOW}⚠ Hadolint not installed - skipping${NC}"
fi

# Bash syntax
run_check "Bash syntax" "bash -n common/scripts/setup.sh"

# HAT configs
run_check "HAT configs" "bash tests/test_hat_configs.sh"

# HAT count
run_check "HAT count (16)" "test \$(ls -1 common/audio-hats/*.conf | wc -l | tr -d ' ') -eq 16"

# Entrypoint and resource profile tests (match remote CI)
run_check "Entrypoint tests" "bash tests/test_entrypoint.sh"
run_check "Resource profiles" "bash tests/test_resource_profiles.sh"

# Python tests
if command -v pytest &> /dev/null; then
    run_check "Python tests" "pytest tests/ -q --tb=short"
else
    echo -e "${YELLOW}⚠ pytest not installed - skipping${NC}"
fi

echo ""
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✅ All checks passed! Pushing...${NC}"
    exit 0
else
    echo -e "${RED}❌ ${FAILED} check(s) failed!${NC}"
    echo ""
    echo "Fix the issues or bypass with: git push --no-verify"
    exit 1
fi
